rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // The signed-in user owns everything under their own /users/{uid}/...
    // document tree (their profile, stories, vocab, podcast state,
    // youtubeVideos, spotifyItems, etc.). One match covers the whole
    // subtree; subcollections inherit via the document=** glob.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Curated Project Gutenberg catalogue. Public-readable; writes are
    // restricted to server-side admin (push_to_firestore.py).
    match /gutenberg_classics/{bookId} {
      allow read: if true;
      allow write: if false;
    }

    // Cross-user audiobook catalogue: generated stories anyone can play,
    // and public-domain imports (Gutenberg etc.). Per-user progress and
    // vocab stay under /users/{uid}/. Reads are open to signed-in users.
    //
    // Writes:
    //   - CREATE allowed from client when the signed-in user authors it
    //     (createdByUid matches auth uid). Used by generation flow.
    //   - UPDATE / DELETE only via firebase-admin from the server (which
    //     bypasses these rules). Prevents popularity tampering and edits
    //     to other users' catalog entries.
    match /sharedAudiobooks/{audiobookId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /sharedAudiobooks/{audiobookId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
